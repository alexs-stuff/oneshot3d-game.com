{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",

    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,

    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",

  
    "types": ["bun"]
  },
  "exclude": ["node_modules"],
  "include": ["./src/**/*"]
}
