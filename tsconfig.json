{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "paths": {
      "#json_datafiles/*": ["./data/*"]
    }
  },
  "exclude": ["node_modules"],
  "include": ["./src/**/*"]
}
