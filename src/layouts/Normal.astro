---
import "../styles/globals.css";
import wallpaperBg from "#assets/wallpaper.png";
import { Image } from "astro:assets";
import Navbar from "../components/navbar/Navbar.astro";
import Footer from "../components/footer/Footer.astro";
import i18next from "i18next";
import { HeadHrefLangs } from "astro-i18next/components";


const { className, noPadding } = Astro.props as {
  className: string;
  noPadding: boolean;
};
---

<!doctype html>
<html lang={i18next.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OneShot 3D</title>

    <meta property="og:title" content="OneShot 3D" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <link href="https://cdn.alex427.com/fonts/terminus.css" rel="stylesheet" />
    <script src="https://unpkg.com/twemoji@latest/dist/twemoji.min.js" crossorigin="anonymous"></script>

        <HeadHrefLangs />

  </head>
  <body class="h-auto min-h-dvh w-full overflow-x-hidden bg-black">
    <Image
      src={wallpaperBg}
      alt=""
      class="fixed inset-0 -z-50 h-screen w-screen scale-110 object-cover blur-lg select-none"
    />
    <div class="fixed inset-0 -z-49 bg-black/30"></div>
    <Navbar />
    <div
      class={`flex flex-col ${noPadding ? "" : "pt-12"} justify-start items-center font-terminus`}
    >
      <main
        class={`flex flex-col  text-white w-full min-h-screen h-auto ${className != null ? className : ""}`}
      >
        <slot />
      </main>
    </div>

    <Footer />
  </body>
</html>
