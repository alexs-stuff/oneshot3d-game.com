---
import i18next from "i18next";

import { localizePath } from "astro-i18next";

const { buttonText, href } = Astro.props;
---

<a
  data-nav-href={href}
  href={localizePath(href, i18next.language)}
  class="hover:bg-os-primary-bg-hi relative flex h-9 flex-col items-center justify-center rounded-lg px-4 text-center text-[20px] transition-all duration-[127ms]">
  <span class="select-none">{buttonText}</span>
</a>
