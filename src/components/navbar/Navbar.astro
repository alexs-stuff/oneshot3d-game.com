---
import NavbarButton from "./NavbarButton.astro";
import { t } from "i18next";
---

<nav
  class="font-terminus fixed top-0 z-100 flex min-h-12 w-full flex-col bg-black/35 text-white backdrop-blur-xl"
>
  <div
    class="flex h-full w-full flex-row items-center justify-between border-b border-b-white/5 p-1"
  >
    <div class="relative flex h-full w-auto flex-row items-center gap-2 p-0.5">
      <NavbarButton href="/" buttonText={t("navb.home")} />
      <NavbarButton href="/about" buttonText={t("navb.about")} />
      <div
        id="nav-indicator"
        class="absolute bottom-1 h-px bg-white transition-all duration-300 ease-in-out"
      >
      </div>
    </div>
    <div></div>
  </div>
  <div
    class="xss:h-12 xss:text-[20px] flex hidden h-8 w-full flex-row items-center justify-center border-b border-b-white/5 text-[16px]"
  >
    <span>Releasing in <b>N/A</b></span>
  </div>

  <script>
    let savedLeft = 0;
    let savedWidth = 0;
    let hadActive = false;

    function getActiveRect() {
      const links = document.querySelectorAll("[data-nav-href]");
      const indicator = document.getElementById("nav-indicator");
      if (!indicator) return null;

      const parent = indicator.parentElement!;
      const parentRect = parent.getBoundingClientRect();

      for (const el of links) {
        const href = el.getAttribute("data-nav-href")!;
        const active =
          location.pathname === href ||
          (href !== "/" && location.pathname.startsWith(href));
        if (active) {
          const r = (el as HTMLElement).getBoundingClientRect();
          return {
            left: r.left - parentRect.left,
            width: r.width,
          };
        }
      }
      return null;
    }

    function applyIndicator(left: number, width: number, animate: boolean) {
      const indicator = document.getElementById("nav-indicator");
      if (!indicator) return;

      indicator.style.transition = animate
        ? "left 127ms, width 127ms ease, margin-left 127ms ease"
        : "none";
      indicator.style.left = `${left}px`;
      indicator.style.width = `${width}px`;
      indicator.style.bottom = "-5px";

      indicator.style.opacity = "1";
    }
    const init = getActiveRect();
    if (init) {
      savedLeft = init.left;
      savedWidth = init.width;
      hadActive = true;
      applyIndicator(init.left, init.width, false);
    }

    document.addEventListener("astro:before-preparation", () => {
      const rect = getActiveRect();
      if (rect) {
        savedLeft = rect.left;
        savedWidth = rect.width;
        hadActive = true;
      } else {
        hadActive = false;
      }
    });

    document.addEventListener("astro:after-swap", () => {
      const indicator = document.getElementById("nav-indicator");
      if (!indicator) return;

      if (hadActive) {
        applyIndicator(savedLeft, savedWidth, false);
      }

      document.body.offsetHeight;

      const newRect = getActiveRect();
      if (newRect) {
        applyIndicator(newRect.left, newRect.width, true);
      } else {
        indicator.style.transition = "opacity 127ms ease";
        indicator.style.opacity = "0";
      }
    });
  </script>
</nav>
