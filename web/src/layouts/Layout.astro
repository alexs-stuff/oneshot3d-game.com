---
import Cursor from "../components/Cursor.astro";
import "../styles/global.css";
import '@fontsource/inter';

interface LayoutProps {
	extraClass?: string,
	efxEnabled?: boolean;
	centeredItems?: boolean;
}

const {extraClass, efxEnabled, centeredItems} = Astro.props as LayoutProps
---

<html lang="en">

	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1"/>
		<meta name="generator" content={Astro.generator} />
		<title>OneShot 3D</title>

	</head>



	<body class={`text-center w-full h-full bg-black text-white ${extraClass}`}>
		<Cursor/>
		
		<div class={`${efxEnabled ? "app" : ""} w-full h-full`}>
			<div class={`${centeredItems ? "flex flex-col justify-center items-center w-full h-full gap-2" : ""}`}>
				<slot/>
			</div>
			
		</div>
	</body>
	
</html>


