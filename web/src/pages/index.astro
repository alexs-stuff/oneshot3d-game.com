---
import { GetCountdown } from "#hooks/countdown";

import Socials from "../components/Socials.astro";
import Layout from "../layouts/Layout.astro";

---

<head>
  <meta property="og:title" content="OneShot 3D" />
  <meta property="og:description" content="Coming soon...\n -alex" />
</head>

<Layout efxEnabled={true} extraClass="bg-radial from-[#281328]/75 to-black " extraClassApp="flex flex-col justify-center items-center">
    <span class="text-[42px] font-black w-full" id="countdown"></span>
    <div class="flex flex-row w-full flex-wrap justify-center items-center">
        <Socials/>
    </div>
  </div>
</Layout>
<script>
import { GetCountdown, type CountdownData } from "#hooks/countdown.js";

let audioPlaying = false;
let audio: HTMLAudioElement | null = null;
let tickAudio: HTMLAudioElement | null = null;

function formatTime(ms: number): string {
  if (ms <= 0) return "00:00:00:00";

  const totalSeconds = Math.floor(ms / 1000);
  const days = Math.floor(totalSeconds / 86400);
  const hours = Math.floor((totalSeconds % 86400) / 3600);
  const minutes = Math.floor((totalSeconds % 3600) / 60);
  const seconds = totalSeconds % 60;

  const pad = (n: number) => n.toString().padStart(2, "0");
  return `${pad(days)}:${pad(hours)}:${pad(minutes)}:${pad(seconds)}`;
}

function startMusic(src: string) {
  if (audioPlaying) return;
  audio = new Audio(src);
  audio.loop = true;
  audio.volume = 0.5;
  audio.play().catch((e) => console.warn("audio blocked by browser:", e));
  audioPlaying = true;
}

function stopMusic() {
  if (audio) {
    audio.pause();
    audio.currentTime = 0;
    audio = null;
  }
  audioPlaying = false;
}

function playTick() {
  tickAudio = new Audio("/sfx/tick.wav");
  tickAudio.volume = 0.3;
  tickAudio.play().catch((e) => console.warn("tick blocked:", e));
}

async function init() {
  const el = document.getElementById("countdown");
  if (!el) return;

  const data = await GetCountdown();

  if (!data.enabled) {
    stopMusic();
    return;
  }

  startMusic("/audio/thetower.ogg");

  el.textContent = formatTime(data.ends_at - Date.now());

  setInterval(() => {
    const remaining = data.ends_at - Date.now();
    if (remaining <= 0) {
      el.textContent = formatTime(0);
      stopMusic();
      return;
    }
    el.textContent = formatTime(remaining);
    playTick();
  }, 1000);
}

init();
</script>