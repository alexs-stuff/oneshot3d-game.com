---
const { buttonText, href } = Astro.props;

const isActive = Astro.url.pathname === href || (href !== "/" && Astro.url.pathname.startsWith(href));
---

<a href={href} class={`flex flex-col items-center justify-center
    h-[75%] px-4 text-center text-[22px]  rounded-lg
    ${isActive ? "bg-white/20  hover:bg-white/30" : "hover:bg-white/15   "}  transition-[127ms]`}>
    <span class="select-none">{buttonText}</span>
</a>    