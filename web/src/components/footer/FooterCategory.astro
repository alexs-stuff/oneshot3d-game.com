---
const { header } = Astro.props
---

<div class="max-w-screen md:max-w-[50%] w-full grid h-auto grid-cols-1 md:grid-cols-2 items-center text-[20px] text-[#b3b3b3]">
    <span class="text-[28px] text-white text-center md:text-left">{header}</span>
    <div class="flex flex-col md:flex-row justify-end items-center gap-6">
        <slot/>
    </div>
</div>