---
import IconButton from "./IconButton.astro"


export type Social = {
  social: string,
  display_name: string,
  url: string
}


const socials: Social[] = [
    {
        "social": "discord",
        "display_name": "Discord Server",
        "url": "https://discord.gg/E8DnA6ZjJP"
    },
    {
        "social": "telegram",
        "display_name": "Telegram Channel",
        "url": "https://t.me/oneshot3d"
    },
    {
        "social": "tiktok",
        "display_name": "Game Devlogs (TikTok)",
        "url": "https://tiktok.com/@al_ex427"
    }
]
---
{socials?.map((social: Social) => (
        <IconButton href={social.url} icon={social.social} alt={social.display_name} />
))}